# Server-only AI / document processing (never use NEXT_PUBLIC_ for secrets)

AI_PROVIDER_URL=
AI_PROVIDER_KEY=
AI_MODEL_FREE=mineru25
AI_MODEL_PRO=gpt-4.1-mini

# Optional: OpenAI-compatible embeddings model (defaults in code if unset)
# AI_EMBEDDING_MODEL=text-embedding-3-small

DOC_PROCESSING_MODE=auto

# Dev-only: show processing debug panel + POST test (non-production only)
ENABLE_DEV_ENGINE_PANEL=false

# Optional: comma-separated Supabase user IDs that map to pro-tier processing
# AI_PRO_USER_IDS=
